---
import Base   from './Base.astro'
import Nav    from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title:       string
  description: string
  label?:      string   // section badge e.g. "Product"
  hero?:       string   // big headline
  sub?:        string   // subheadline
}
const { title, description, label, hero, sub } = Astro.props
---
<Base title={`${title} — Krenla`} description={description}>
  <Nav />

  <!-- Page hero -->
  <header class="page-hero">
    <div class="orb pa" aria-hidden="true"></div>
    <div class="orb pb" aria-hidden="true"></div>
    <div class="container">
      {label && <div class="sec-label">{label}</div>}
      <h1>{hero ?? title}</h1>
      {sub && <p class="page-sub">{sub}</p>}
    </div>
  </header>

  <main class="page-main">
    <div class="container">
      <slot />
    </div>
  </main>

  <Footer />
</Base>

<style>
.page-hero {
  position: relative; overflow: hidden;
  padding: 140px 24px 72px; text-align: center;
  border-bottom: 1px solid var(--border);
}
.orb { position: absolute; border-radius: 50%; pointer-events: none; }
.pa {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(124,92,252,.16) 0%, transparent 68%);
  filter: blur(80px); top: -150px; left: -100px;
}
.pb {
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(75,139,245,.12) 0%, transparent 68%);
  filter: blur(70px); top: -80px; right: -80px;
}
.page-hero .sec-label { justify-content: center; margin-bottom: 16px; }
.page-hero h1 {
  font-size: clamp(2rem, 4.5vw, 3.75rem);
  font-weight: 900; letter-spacing: -.045em; line-height: 1.07;
  max-width: 720px; margin: 0 auto 18px;
}
.page-sub {
  font-size: clamp(.95rem, 1.6vw, 1.15rem);
  color: var(--text2); max-width: 560px; margin: 0 auto; line-height: 1.7;
}
.page-main { padding: 80px 24px 120px; }

/* Prose content shared across pages */
:global(.prose) { max-width: 740px; margin: 0 auto; }
:global(.prose h2) {
  font-size: 1.5rem; font-weight: 800; letter-spacing: -.03em;
  margin: 56px 0 16px; color: var(--text);
}
:global(.prose h2:first-child) { margin-top: 0; }
:global(.prose h3) {
  font-size: 1.05rem; font-weight: 700; margin: 32px 0 10px;
}
:global(.prose p) {
  font-size: .97rem; color: var(--text2); line-height: 1.78; margin-bottom: 18px;
}
:global(.prose ul, .prose ol) {
  padding-left: 22px; display: flex; flex-direction: column; gap: 10px;
  margin-bottom: 18px;
}
:global(.prose li) { font-size: .97rem; color: var(--text2); line-height: 1.7; }
:global(.prose strong) { color: var(--text); font-weight: 600; }
:global(.prose a) { color: var(--purple2); text-decoration: none; border-bottom: 1px solid rgba(157,130,255,.3); transition: border-color .2s; }
:global(.prose a:hover) { border-color: var(--purple2); }
:global(.prose .note) {
  background: rgba(124,92,252,.08); border: 1px solid rgba(124,92,252,.2);
  border-radius: 10px; padding: 16px 20px; margin: 28px 0;
  font-size: .9rem; color: var(--text2); line-height: 1.7;
}
:global(.prose .updated) {
  font-size: .8rem; color: var(--text3); margin-bottom: 40px;
}

/* Card grid used in product pages */
:global(.card-grid) {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 14px; margin: 40px 0;
}
:global(.card) {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r); padding: 28px; transition: all .25s;
}
:global(.card:hover) {
  border-color: rgba(124,92,252,.25); transform: translateY(-2px);
  box-shadow: 0 12px 40px rgba(0,0,0,.3);
}
:global(.card-ic) {
  width: 40px; height: 40px; border-radius: 10px;
  background: rgba(124,92,252,.1); border: 1px solid rgba(124,92,252,.18);
  display: flex; align-items: center; justify-content: center; margin-bottom: 14px;
}
:global(.card-ic svg) { width: 18px; height: 18px; }
:global(.card h3) { font-size: .97rem; font-weight: 700; margin-bottom: 8px; }
:global(.card p) { font-size: .855rem; color: var(--text2); line-height: 1.65; margin: 0; }

/* Pricing */
:global(.plan-grid) {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 14px; margin: 40px 0;
}
:global(.plan) {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r); padding: 32px 26px;
}
:global(.plan.featured) {
  background: linear-gradient(150deg,rgba(124,92,252,.1),rgba(75,139,245,.05));
  border-color: rgba(124,92,252,.35);
}
:global(.plan-name) { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--text3); margin-bottom: 12px; }
:global(.plan-price) { font-size: 2.6rem; font-weight: 900; letter-spacing: -.04em; margin-bottom: 4px; }
:global(.plan-price span) { font-size: 1rem; font-weight: 500; color: var(--text3); }
:global(.plan-desc) { font-size: .84rem; color: var(--text2); margin-bottom: 24px; line-height: 1.6; }
:global(.plan-features) { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 28px; }
:global(.plan-features li) { display: flex; align-items: center; gap: 8px; font-size: .84rem; color: var(--text2); }
:global(.plan-features li::before) { content: '✓'; color: #22C55E; font-weight: 700; flex-shrink: 0; }
:global(.btn-plan) {
  display: block; text-align: center; padding: 11px; border-radius: 9px;
  font-size: .88rem; font-weight: 600; text-decoration: none; transition: all .2s;
  border: 1px solid var(--border2); color: var(--text);
}
:global(.btn-plan:hover) { background: var(--surface2); }
:global(.btn-plan.primary) {
  background: linear-gradient(135deg,var(--purple),var(--blue));
  border-color: transparent; color: #fff;
  box-shadow: 0 0 30px rgba(124,92,252,.3);
}
:global(.btn-plan.primary:hover) { box-shadow: 0 0 50px rgba(124,92,252,.45); }

/* Team grid */
:global(.team-grid) {
  display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; margin: 40px 0;
}
:global(.member) {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r); padding: 28px; text-align: center;
}
:global(.member-av) {
  width: 64px; height: 64px; border-radius: 50%; margin: 0 auto 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem; font-weight: 800;
}
:global(.member-name) { font-size: .95rem; font-weight: 700; margin-bottom: 4px; }
:global(.member-role) { font-size: .78rem; color: var(--text3); }

@media(max-width:700px) {
  :global(.card-grid)  { grid-template-columns: 1fr; }
  :global(.plan-grid)  { grid-template-columns: 1fr; }
  :global(.team-grid)  { grid-template-columns: 1fr 1fr; }
}
</style>
