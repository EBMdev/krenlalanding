---
const communities = [
  {
    name: 'Gaming Nexus', tag: 'Gaming · Entertainment', members: '84,200',
    desc: 'Reviews, live sessions, team-ups — the hub for every kind of gamer.',
    color: 'rgba(124,92,252,.12)', stroke: 'rgba(157,130,255,.8)',
    icon: '<rect x="2" y="4" width="18" height="14" rx="2" stroke="rgba(157,130,255,.8)" stroke-width="1.5"/><path d="M8 9l4 3-4 3V9Z" fill="rgba(157,130,255,.8)"/>'
  },
  {
    name: 'Tech & Dev', tag: 'Technology · Programming', members: '112,000',
    desc: 'Code reviews, career advice, and technical deep-dives. Developers and designers building together.',
    color: 'rgba(75,139,245,.12)', stroke: 'rgba(130,175,255,.8)',
    icon: '<rect x="3" y="3" width="16" height="16" rx="2" stroke="rgba(130,175,255,.8)" stroke-width="1.5"/><path d="M7 11l3 3 5-5" stroke="rgba(130,175,255,.8)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>'
  },
  {
    name: 'Design Lab', tag: 'Design · Creative', members: '47,600',
    desc: 'Share work, get honest feedback, explore trends, and collaborate with creatives across every discipline.',
    color: 'rgba(43,191,170,.1)', stroke: 'rgba(43,191,170,.8)',
    icon: '<path d="M11 3L19 7v8l-8 4L3 15V7L11 3Z" stroke="rgba(43,191,170,.8)" stroke-width="1.5" stroke-linejoin="round"/>'
  },
  {
    name: 'Startup Founders', tag: 'Business · Startups', members: '29,300',
    desc: 'Pitch ideas, find co-founders, trade fundraising stories, and navigate the startup journey with people who get it.',
    color: 'rgba(245,158,11,.1)', stroke: 'rgba(245,158,11,.8)',
    icon: '<path d="M11 3l2 6h6l-5 4 2 6-5-4-5 4 2-6-5-4h6L11 3Z" stroke="rgba(245,158,11,.8)" stroke-width="1.5" stroke-linejoin="round"/>'
  },
  {
    name: 'AI & the Future', tag: 'AI · Machine Learning', members: '65,800',
    desc: 'Breakthrough discussions, model sharing, ethics debates, and the people building the next generation of intelligence.',
    color: 'rgba(239,68,68,.08)', stroke: 'rgba(239,130,130,.8)',
    icon: '<circle cx="11" cy="11" r="7" stroke="rgba(239,130,130,.8)" stroke-width="1.5"/><path d="M8 11h6M11 8v6" stroke="rgba(239,130,130,.8)" stroke-width="1.4" stroke-linecap="round"/>'
  },
  {
    name: 'Learn Together', tag: 'Education · Skills', members: '38,100',
    desc: 'Study groups, mentorship, resource sharing, and accountability across every subject and skill level.',
    color: 'rgba(75,139,245,.1)', stroke: 'rgba(130,175,255,.8)',
    icon: '<path d="M4 6h14M4 10h10M4 14h12" stroke="rgba(130,175,255,.8)" stroke-width="1.5" stroke-linecap="round"/>'
  },
]
---
<section id="communities" class="py">
  <div class="container">
    <div class="tc reveal">
      <div class="sec-label">Communities</div>
      <h2 class="sec-title">Find your people</h2>
      <p class="sec-sub">Thousands of active communities — from niche interests to fields that are shaping the world.</p>
    </div>

    <div class="comm-grid">
      {communities.map(c => (
        <article class="comm-card reveal">
          <div class="comm-head">
            <div class="comm-icon" style={`background:${c.color}`}>
              <svg viewBox="0 0 22 22" fill="none" set:html={c.icon} />
            </div>
            <div>
              <div class="comm-name">{c.name}</div>
              <div class="comm-tag">{c.tag}</div>
            </div>
          </div>
          <p class="comm-desc">{c.desc}</p>
          <div class="comm-foot">
            <span class="comm-count">{c.members} members</span>
            <div class="live">
              <div class="live-dot"></div>
              <span class="live-label">Active now</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.comm-grid {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 14px; margin-top: 60px;
}
.comm-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r); padding: 26px; cursor: pointer; transition: all .3s;
}
.comm-card:hover {
  border-color: rgba(124,92,252,.28); transform: translateY(-3px);
  box-shadow: 0 18px 50px rgba(0,0,0,.35), 0 0 0 1px rgba(124,92,252,.08);
}
.comm-head   { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
.comm-icon   { width: 46px; height: 46px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.comm-icon svg { width: 22px; height: 22px; }
.comm-name   { font-size: .95rem; font-weight: 700; line-height: 1.2; }
.comm-tag    { font-size: .7rem; color: var(--text3); font-weight: 500; margin-top: 1px; }
.comm-desc   { font-size: .8rem; color: var(--text2); line-height: 1.62; margin-bottom: 18px; }
.comm-foot   { display: flex; align-items: center; justify-content: space-between; }
.comm-count  { font-size: .75rem; color: var(--text2); }
.live        { display: flex; align-items: center; gap: 5px; }
.live-dot    { width: 6px; height: 6px; border-radius: 50%; background: #22C55E; animation: blink 2s infinite; }
.live-label  { font-size: .7rem; color: #22C55E; font-weight: 500; }

@media (max-width: 900px) { .comm-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 600px) { .comm-grid { grid-template-columns: 1fr; } }
</style>
