---
---
<section class="hero">
  <!-- Background orbs -->
  <div class="orb orb-a" aria-hidden="true"></div>
  <div class="orb orb-b" aria-hidden="true"></div>
  <div class="orb orb-c" aria-hidden="true"></div>

  <div class="hero-label">
    <span class="pulse" aria-hidden="true"></span>
    Public beta — 500K+ people already here
  </div>

  <h1>
    Where communities,<br/>
    conversations, and<br/>
    <span class="grad">knowledge connect</span>
  </h1>

  <p>
    Real-time chats, shared spaces, and meaningful discussion —
    all in one place, for people who care about building something together.
  </p>

  <div class="hero-btns">
    <a class="btn-primary" href="#">
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
        <path d="M7.5 1.5L13 7.5L7.5 13.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M2 7.5H13" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      Get started free
    </a>
    <a class="btn-secondary" href="#">Explore communities</a>
  </div>

  <!-- App Mockup -->
  <div class="mockup-wrap">
    <div class="mockup-glow" aria-hidden="true"></div>
    <div class="window" role="img" aria-label="Krenla app interface preview">
      <!-- Titlebar -->
      <div class="titlebar" aria-hidden="true">
        <span class="tb-dot tb-r"></span>
        <span class="tb-dot tb-y"></span>
        <span class="tb-dot tb-g"></span>
        <span class="tb-url">krenla.com / communities / tech-and-dev</span>
      </div>

      <!-- App body -->
      <div class="app-body">

        <!-- Server rail -->
        <div class="rail">
          <div class="srv on">
            <svg viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="6" height="6" rx="1.5" fill="white"/><rect x="11" y="3" width="6" height="6" rx="1.5" fill="white" opacity=".5"/><rect x="3" y="11" width="6" height="6" rx="1.5" fill="white" opacity=".5"/><rect x="11" y="11" width="6" height="6" rx="1.5" fill="white" opacity=".5"/></svg>
          </div>
          <div class="srv">
            <svg viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="5" fill="white"/></svg>
          </div>
          <div class="srv">
            <svg viewBox="0 0 20 20" fill="none"><path d="M5 10h10M5 6h10M5 14h6" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <div class="rail-div"></div>
          <div class="srv">
            <svg viewBox="0 0 20 20" fill="none"><path d="M10 4v12M4 10h12" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
        </div>

        <!-- Channel list -->
        <div class="channels">
          <div class="ch-sec">
            <p class="ch-head">Text channels</p>
            <div class="ch-item on">
              <svg viewBox="0 0 16 16" fill="none"><path d="M2 4h12M2 8h8M2 12h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
              general
              <span class="ch-badge">4</span>
            </div>
            <div class="ch-item">
              <svg viewBox="0 0 16 16" fill="none"><path d="M2 4h12M2 8h8M2 12h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
              announcements
            </div>
            <div class="ch-item">
              <svg viewBox="0 0 16 16" fill="none"><path d="M2 4h12M2 8h8M2 12h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
              showcase
            </div>
          </div>
          <div class="ch-sec">
            <p class="ch-head">Voice rooms</p>
            <div class="ch-item">
              <svg viewBox="0 0 16 16" fill="none"><path d="M8 2a3 3 0 0 1 3 3v3a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3Z" stroke="currentColor" stroke-width="1.3"/><path d="M4 8a4 4 0 0 0 8 0M8 12v2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
              Lounge
            </div>
            <div class="ch-item">
              <svg viewBox="0 0 16 16" fill="none"><path d="M8 2a3 3 0 0 1 3 3v3a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3Z" stroke="currentColor" stroke-width="1.3"/><path d="M4 8a4 4 0 0 0 8 0M8 12v2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
              Study Hall
            </div>
          </div>
          <div class="ch-sec">
            <p class="ch-head">Threads</p>
            <div class="ch-item">
              <svg viewBox="0 0 16 16" fill="none"><path d="M2 3h12v7H8l-4 3V10H2V3Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
              Weekly review
            </div>
          </div>
        </div>

        <!-- Chat area -->
        <div class="chat">
          <div class="chat-bar">
            <span class="chat-title"># general</span>
            <span class="chat-meta">241 members online</span>
          </div>
          <div class="messages">
            <div class="msg">
              <div class="av" style="background:linear-gradient(135deg,#7C5CFC,#4B8BF5)">AL</div>
              <div class="mb">
                <div class="mb-name">alex_dev <time>2:14 PM</time></div>
                <p class="mb-text">Just shipped the new dashboard — real-time sync is working perfectly now.</p>
                <div class="reactions">
                  <span class="rx">+1 · 12</span>
                  <span class="rx">fire · 8</span>
                </div>
              </div>
            </div>
            <div class="msg">
              <div class="av" style="background:linear-gradient(135deg,#2BBFAA,#4B8BF5)">SR</div>
              <div class="mb">
                <div class="mb-name">sara_ui <time>2:17 PM</time></div>
                <p class="mb-text">Looks great. Love the updated card layout — did you use the new component library?</p>
              </div>
            </div>
            <div class="msg">
              <div class="av" style="background:linear-gradient(135deg,#F59E0B,#EF4444)">MK</div>
              <div class="mb">
                <div class="mb-name">marco <time>2:20 PM</time></div>
                <p class="mb-text">This is why I keep coming back — best dev community around.</p>
              </div>
            </div>
          </div>
          <div class="chat-input">
            <span>Message #general…</span>
            <div class="ci-icons" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"/><path d="M5.5 9.5c.7.9 4.3.9 5 0" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="6" cy="7" r=".8" fill="currentColor"/><circle cx="10" cy="7" r=".8" fill="currentColor"/></svg>
              <svg viewBox="0 0 16 16" fill="none"><path d="M3 4h10M3 8h6M3 12h8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
              <svg viewBox="0 0 16 16" fill="none"><path d="M8 2a3 3 0 0 1 3 3v3a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3Z" stroke="currentColor" stroke-width="1.3"/></svg>
            </div>
          </div>
        </div>

        <!-- Right panel -->
        <div class="panel">
          <div>
            <p class="panel-head">Trending</p>
            <div class="trend-item">
              <div class="trend-ic" style="background:rgba(124,92,252,.14)">
                <svg viewBox="0 0 16 16" fill="none"><path d="M8 2l1.5 3H13l-2.8 2 1.1 3.3L8 8.4 4.7 10.3l1.1-3.3L3 5h3.5L8 2Z" fill="rgba(157,130,255,.8)"/></svg>
              </div>
              <div>
                <p class="trend-name">AI Tools 2025</p>
                <p class="trend-count">2.4k posts today</p>
              </div>
            </div>
            <div class="trend-item">
              <div class="trend-ic" style="background:rgba(75,139,245,.14)">
                <svg viewBox="0 0 16 16" fill="none"><rect x="2" y="4" width="12" height="8" rx="1.5" stroke="rgba(130,175,255,.8)" stroke-width="1.3"/></svg>
              </div>
              <div>
                <p class="trend-name">Open Source</p>
                <p class="trend-count">1.1k posts today</p>
              </div>
            </div>
            <div class="trend-item">
              <div class="trend-ic" style="background:rgba(43,191,170,.12)">
                <svg viewBox="0 0 16 16" fill="none"><path d="M8 2L14 6v8H2V6L8 2Z" stroke="rgba(43,191,170,.8)" stroke-width="1.3" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <p class="trend-name">Startup Launches</p>
                <p class="trend-count">890 posts today</p>
              </div>
            </div>
          </div>
          <div>
            <p class="panel-head">Online now</p>
            <div class="online-item"><div class="odot"></div>alex_dev</div>
            <div class="online-item"><div class="odot"></div>sara_ui</div>
            <div class="online-item"><div class="odot"></div>marco</div>
            <div class="online-item dim"><div class="odot dim-dot"></div>+238 others</div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
.hero {
  position: relative; min-height: 100svh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center; padding: 130px 24px 72px; overflow: hidden;
}

/* Orbs */
.orb { position: absolute; border-radius: 50%; pointer-events: none; animation: drift 10s ease-in-out infinite; }
.orb-a { width:700px;height:700px; background:radial-gradient(circle,rgba(124,92,252,.18) 0%,transparent 68%); filter:blur(80px); top:-160px;left:-220px; }
.orb-b { width:520px;height:520px; background:radial-gradient(circle,rgba(75,139,245,.14) 0%,transparent 68%); filter:blur(80px); top:0;right:-180px; animation-delay:-4s; }
.orb-c { width:380px;height:380px; background:radial-gradient(circle,rgba(43,191,170,.12) 0%,transparent 68%); filter:blur(60px); bottom:40px;left:38%; animation-delay:-7s; }

/* Label */
.hero-label {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(124,92,252,.1); border: 1px solid rgba(124,92,252,.25);
  border-radius: 100px; padding: 5px 14px 5px 8px;
  font-size: .78rem; font-weight: 500; color: var(--purple2);
  margin-bottom: 28px; animation: fadeup .7s ease both;
}
.pulse {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--cyan); animation: blink 2.2s ease-in-out infinite;
}

/* Headline */
h1 {
  font-size: clamp(2.4rem, 5.5vw, 4.75rem);
  font-weight: 900; letter-spacing: -.045em; line-height: 1.05;
  max-width: 800px; margin-bottom: 22px;
  animation: fadeup .7s ease .1s both;
}
p {
  font-size: clamp(.95rem, 1.8vw, 1.15rem); color: var(--text2);
  max-width: 530px; line-height: 1.72; margin-bottom: 36px;
  animation: fadeup .7s ease .18s both;
}

/* Buttons */
.hero-btns {
  display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;
  margin-bottom: 72px; animation: fadeup .7s ease .26s both;
}

/* Mockup */
.mockup-wrap { width: 100%; max-width: 980px; position: relative; animation: fadeup .9s ease .36s both; }
.mockup-glow {
  position: absolute; bottom: -60px; left: 50%; transform: translateX(-50%);
  width: 70%; height: 120px; border-radius: 50%;
  background: rgba(124,92,252,.18); filter: blur(40px); pointer-events: none;
}
.window {
  background: rgba(13,13,24,.82); backdrop-filter: blur(30px);
  border: 1px solid rgba(255,255,255,.08); border-radius: 18px; overflow: hidden;
  box-shadow: 0 2px 0 rgba(255,255,255,.06) inset, 0 60px 120px rgba(0,0,0,.65), 0 0 80px rgba(124,92,252,.08);
}
.titlebar {
  display: flex; align-items: center; gap: 7px;
  padding: 13px 18px; border-bottom: 1px solid var(--border);
  background: rgba(255,255,255,.02);
}
.tb-dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
.tb-r { background: #FF5F57; } .tb-y { background: #FFBD2E; } .tb-g { background: #28CA41; }
.tb-url {
  flex: 1; background: rgba(255,255,255,.04); border-radius: 5px;
  padding: 4px 11px; font-size: .72rem; color: var(--text3); margin: 0 14px;
}
.app-body { display: grid; grid-template-columns: 60px 200px 1fr 220px; height: 360px; }

/* Rail */
.rail {
  background: rgba(0,0,0,.28); border-right: 1px solid var(--border);
  display: flex; flex-direction: column; align-items: center; padding: 14px 0; gap: 8px;
}
.srv {
  width: 40px; height: 40px; border-radius: 13px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all .2s;
}
.srv.on { background: linear-gradient(135deg, var(--purple), var(--blue)); border-radius: 15px; }
.srv:not(.on) { background: rgba(255,255,255,.055); }
.srv:not(.on):hover { background: rgba(255,255,255,.1); border-radius: 15px; }
.srv svg { width: 18px; height: 18px; opacity: .7; }
.srv.on svg { opacity: 1; }
.rail-div { width: 24px; height: 1px; background: var(--border); }

/* Channels */
.channels {
  border-right: 1px solid var(--border); padding: 14px 0;
  overflow: hidden; display: flex; flex-direction: column;
}
.ch-sec { padding: 0 10px 10px; }
.ch-head {
  font-size: .64rem; font-weight: 700; letter-spacing: .09em;
  text-transform: uppercase; color: var(--text3); padding: 4px 6px 8px;
}
.ch-item {
  display: flex; align-items: center; gap: 7px; padding: 6px 8px;
  border-radius: 6px; font-size: .77rem; color: var(--text2);
  cursor: pointer; transition: all .15s;
}
.ch-item:hover { background: var(--surface); color: var(--text); }
.ch-item.on { background: rgba(124,92,252,.14); color: var(--text); }
.ch-item svg { width: 14px; height: 14px; opacity: .45; flex-shrink: 0; }
.ch-badge {
  margin-left: auto; background: var(--purple); color: #fff;
  font-size: .58rem; font-weight: 700; padding: 1px 5px; border-radius: 100px;
}

/* Chat */
.chat { display: flex; flex-direction: column; overflow: hidden; }
.chat-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 16px; border-bottom: 1px solid var(--border); flex-shrink: 0;
}
.chat-title { font-size: .82rem; font-weight: 600; }
.chat-meta { font-size: .68rem; color: var(--text3); }
.messages {
  flex: 1; padding: 14px 16px; display: flex;
  flex-direction: column; gap: 12px; overflow: hidden;
}
.msg { display: flex; gap: 10px; }
.av {
  width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: .72rem; font-weight: 700;
}
.mb { flex: 1; overflow: hidden; }
.mb-name { font-size: .77rem; font-weight: 600; margin-bottom: 2px; }
.mb-name time { font-weight: 400; font-size: .65rem; color: var(--text3); margin-left: 6px; }
.mb-text { font-size: .75rem; color: var(--text2); line-height: 1.55; }
.reactions { display: flex; gap: 5px; margin-top: 5px; }
.rx {
  display: inline-flex; align-items: center; gap: 4px;
  background: rgba(255,255,255,.05); border: 1px solid var(--border);
  border-radius: 100px; padding: 2px 7px; font-size: .67rem; cursor: pointer;
}
.chat-input {
  margin: 10px 14px 14px; display: flex; align-items: center; gap: 10px;
  background: rgba(255,255,255,.05); border: 1px solid var(--border);
  border-radius: 9px; padding: 9px 12px;
  font-size: .75rem; color: var(--text3); flex-shrink: 0;
}
.chat-input span { flex: 1; }
.ci-icons { display: flex; gap: 9px; }
.ci-icons svg { width: 14px; height: 14px; opacity: .35; }

/* Panel */
.panel {
  border-left: 1px solid var(--border); padding: 14px 12px;
  display: flex; flex-direction: column; gap: 16px; overflow: hidden;
}
.panel-head {
  font-size: .64rem; font-weight: 700; letter-spacing: .09em;
  text-transform: uppercase; color: var(--text3); margin-bottom: 10px;
}
.trend-item {
  display: flex; align-items: center; gap: 9px;
  padding: 7px 6px; border-radius: 7px; cursor: pointer; transition: background .15s;
}
.trend-item:hover { background: var(--surface); }
.trend-ic {
  width: 30px; height: 30px; border-radius: 7px;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.trend-ic svg { width: 15px; height: 15px; }
.trend-name { font-size: .73rem; font-weight: 600; line-height: 1.3; }
.trend-count { font-size: .63rem; color: var(--text3); }
.online-item {
  display: flex; align-items: center; gap: 7px;
  font-size: .73rem; color: var(--text2); padding: 3px 0;
}
.odot { width: 7px; height: 7px; border-radius: 50%; background: #22C55E; flex-shrink: 0; }
.dim { color: var(--text3); }
.dim-dot { background: var(--text3); }

@media (max-width: 900px) {
  .app-body { grid-template-columns: 56px 1fr; height: 280px; }
  .panel, .channels { display: none; }
}
</style>
