---
import Page from '../../layouts/Page.astro'

const categories = [
  { name: 'Technology', count: '12,400 communities', color: 'rgba(75,139,245,.12)', stroke: 'rgba(130,175,255,.8)', icon: '<rect x="3" y="3" width="16" height="16" rx="2" stroke="rgba(130,175,255,.8)" stroke-width="1.5"/><path d="M7 11l3 3 5-5" stroke="rgba(130,175,255,.8)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>' },
  { name: 'Gaming', count: '9,800 communities', color: 'rgba(124,92,252,.12)', stroke: 'rgba(157,130,255,.8)', icon: '<rect x="2" y="4" width="18" height="14" rx="2" stroke="rgba(157,130,255,.8)" stroke-width="1.5"/><path d="M8 9l4 3-4 3V9Z" fill="rgba(157,130,255,.8)"/>' },
  { name: 'Design & Creative', count: '5,200 communities', color: 'rgba(43,191,170,.1)', stroke: 'rgba(43,191,170,.8)', icon: '<path d="M11 3L19 7v8l-8 4L3 15V7L11 3Z" stroke="rgba(43,191,170,.8)" stroke-width="1.5" stroke-linejoin="round"/>' },
  { name: 'Science', count: '3,900 communities', color: 'rgba(245,158,11,.1)', stroke: 'rgba(245,158,11,.8)', icon: '<circle cx="11" cy="11" r="6" stroke="rgba(245,158,11,.8)" stroke-width="1.5"/><path d="M11 8v3l2 2" stroke="rgba(245,158,11,.8)" stroke-width="1.4" stroke-linecap="round"/>' },
  { name: 'AI & Machine Learning', count: '4,700 communities', color: 'rgba(239,68,68,.08)', stroke: 'rgba(239,130,130,.8)', icon: '<circle cx="11" cy="11" r="7" stroke="rgba(239,130,130,.8)" stroke-width="1.5"/><path d="M8 11h6M11 8v6" stroke="rgba(239,130,130,.8)" stroke-width="1.4" stroke-linecap="round"/>' },
  { name: 'Education', count: '6,100 communities', color: 'rgba(75,139,245,.1)', stroke: 'rgba(130,175,255,.8)', icon: '<path d="M4 6h14M4 10h10M4 14h12" stroke="rgba(130,175,255,.8)" stroke-width="1.5" stroke-linecap="round"/>' },
]
---
<Page
  title="Communities"
  label="Product"
  hero="Every interest has a home"
  sub="Explore communities built around the things that matter to you — or create your own in minutes."
  description="Browse and discover communities on Krenla across gaming, tech, design, science, and more."
>
  <div class="cat-grid">
    {categories.map(c => (
      <a class="cat-card" href="#">
        <div class="cat-ic" style={`background:${c.color}`}>
          <svg viewBox="0 0 22 22" fill="none" set:html={c.icon} />
        </div>
        <div class="cat-name">{c.name}</div>
        <div class="cat-count">{c.count}</div>
      </a>
    ))}
  </div>

  <div class="prose">
    <h2>Create your own community</h2>
    <p>Starting a community on Krenla takes under two minutes. Give it a name, a description, and choose who can join — public, invite-only, or private. Then set up your channels, invite your first members, and you're live.</p>

    <h2>Community tools</h2>
    <p>Every community comes with channels, threads, voice rooms, and a member directory out of the box. As your community grows, you can add moderators, create custom roles, set up automated welcome messages, and configure rules that keep the culture healthy.</p>

    <h2>Moderation</h2>
    <p>Krenla gives community owners and moderators the tools they need: message filtering, slow mode, temporary and permanent bans, appeal workflows, and a full audit log. Large communities can also apply for a dedicated trust and safety contact.</p>

    <div class="note">
      <strong>Looking for a specific community?</strong> Use the discovery feed on the app to search by name, topic, or keyword. You can filter by language, size, and activity level.
    </div>
  </div>
</Page>

<style>
.cat-grid {
  display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; margin-bottom: 64px;
}
.cat-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r); padding: 26px;
  text-decoration: none; transition: all .25s; display: block;
}
.cat-card:hover {
  border-color: rgba(124,92,252,.25); transform: translateY(-2px);
  box-shadow: 0 12px 40px rgba(0,0,0,.3);
}
.cat-ic {
  width: 44px; height: 44px; border-radius: 11px;
  display: flex; align-items: center; justify-content: center; margin-bottom: 14px;
}
.cat-ic svg { width: 22px; height: 22px; }
.cat-name  { font-size: .95rem; font-weight: 700; margin-bottom: 4px; }
.cat-count { font-size: .78rem; color: var(--text3); }
@media(max-width:700px) { .cat-grid { grid-template-columns: 1fr 1fr; } }
</style>
